PORT=3001
# Leave empty in dev to use Vite proxy (same origin). Set full URL if serving static build without proxy.
VITE_API_URL=

# If video thumbs / transcodes fail with spawn ENOENT, set absolute paths (Node may have a minimal PATH).
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

OPENSUBTITLES_KEY=123abc
OPENSUBTITLES_USER=111
OPENSUBTITLES_PASS=222